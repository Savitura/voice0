# Anthropic — server-side only
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Helius Solana RPC — server-side only
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=...

# Client-side RPC (optional — only needed if you want direct client RPC calls)
# EXPO_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
# EXPO_PUBLIC_HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=...

# ElevenLabs STT — SERVER-side only (proxied through /api/transcribe)
ELEVENLABS_API_KEY=...

# Shared secret to gate the API routes. Generate with: openssl rand -hex 32
# Server reads APP_SHARED_SECRET, client sends it as x-app-secret via EXPO_PUBLIC_APP_SECRET.
APP_SHARED_SECRET=
EXPO_PUBLIC_APP_SECRET=

# App name
EXPO_PUBLIC_APP_NAME=voice0

# API base URL — override for production
# EXPO_PUBLIC_BASE_URL=https://your-deployment.com
