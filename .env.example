# Anthropic — server-side only (no EXPO_PUBLIC_ prefix)
ANTHROPIC_API_KEY=sk-ant-...

# Helius Solana RPC — server-side only
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...

# ElevenLabs STT — client-side for MVP (proxy in production)
EXPO_PUBLIC_ELEVENLABS_API_KEY=...

# App name
EXPO_PUBLIC_APP_NAME=voice0

# API base URL — override for production
# EXPO_PUBLIC_BASE_URL=https://your-deployment.com
