<?xml version="1.0" encoding="utf-8"?>
<!--
    voice0 adaptive icon foreground.
    Viewport 108×108. Safe zone x=18..90, y=18..90 (inner 72×72).

    Top: 5 pill-shaped waveform bars, white on black.
    Bars shifted up to make room for wallet card below.

    Bar positions (cx, y-top → y-bottom, height):
      Bar 1: cx=34   y 37→55   h=18
      Bar 2: cx=44   y 32→60   h=28
      Bar 3: cx=54   y 28→64   h=36  (tallest, center)
      Bar 4: cx=64   y 32→60   h=28
      Bar 5: cx=74   y 37→55   h=18

    Bottom: wallet card — filled white rounded rect (38,71)→(70,83)
    with a small black chip cutout at (43,74)→(51,78).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Bar 1 — cx=34, y 37→55, height 18 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,37
                          a3,3 0 0 1 3,3
                          v12
                          a3,3 0 0 1 -3,3
                          a3,3 0 0 1 -3,-3
                          v-12
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Bar 2 — cx=44, y 32→60, height 28 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,32
                          a3,3 0 0 1 3,3
                          v22
                          a3,3 0 0 1 -3,3
                          a3,3 0 0 1 -3,-3
                          v-22
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Bar 3 — cx=54, y 28→64, height 36 (tallest, center) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,28
                          a3,3 0 0 1 3,3
                          v30
                          a3,3 0 0 1 -3,3
                          a3,3 0 0 1 -3,-3
                          v-30
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Bar 4 — cx=64, y 32→60, height 28 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M64,32
                          a3,3 0 0 1 3,3
                          v22
                          a3,3 0 0 1 -3,3
                          a3,3 0 0 1 -3,-3
                          v-22
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Bar 5 — cx=74, y 37→55, height 18 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M74,37
                          a3,3 0 0 1 3,3
                          v12
                          a3,3 0 0 1 -3,3
                          a3,3 0 0 1 -3,-3
                          v-12
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Wallet card body — filled white, (38,71)→(70,83), rx=3 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M41,71
                          h26
                          a3,3 0 0 1 3,3
                          v6
                          a3,3 0 0 1 -3,3
                          h-26
                          a3,3 0 0 1 -3,-3
                          v-6
                          a3,3 0 0 1 3,-3
                          z" />

    <!-- Chip cutout — black, (43,74)→(51,78), rx=1 -->
    <path
        android:fillColor="#000000"
        android:pathData="M44,74
                          h6
                          a1,1 0 0 1 1,1
                          v2
                          a1,1 0 0 1 -1,1
                          h-6
                          a1,1 0 0 1 -1,-1
                          v-2
                          a1,1 0 0 1 1,-1
                          z" />

</vector>
