# Copy to local.properties and fill in. local.properties is gitignored.
# These values are baked into BuildConfig at compile time and ARE extractable
# from a release APK by anyone who downloads it. See README "Security".

sdk.dir=/path/to/Android/Sdk

GROQ_API_KEY=          # free at console.groq.com — no credit card required
ELEVENLABS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
GROQ_MODEL=llama-3.3-70b-versatile
